---
import '../styles/manifesto-theme.css';
import type { DocMeta } from '../lib/doc-meta';

interface Props {
	meta: DocMeta;
}

const { meta } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="color-scheme" content="light dark" />
		<title>{meta.title}</title>
		<meta name="description" content={meta.description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=Inter:wght@400;500&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<a class="skip" href="#content">Skip to content</a>

		<header class="masthead">
			<div class="masthead-inner">
				<div class="title-block">
					<h1 class="title">
						{meta.titleLines.map((line, index) => (
							<>
								{index > 0 && <br />}
								{line}
							</>
						))}
					</h1>
				</div>
			</div>
		</header>

		<main id="content" class="doc-main">
			<slot />
		</main>

		<footer>
			<div class="footer-inner">
				<p>
					Agentic Engineering Manifesto
					{meta.version ? ` · v${meta.version}` : ''}
					{meta.published ? ` · ${meta.published}` : ''}
				</p>
				<div class="footer-meta">
					{meta.status && <span>{meta.status}</span>}
					<a href="https://github.com/mahdavipanah/agentic-engineering-manifesto">
						View on GitHub
					</a>
				</div>
			</div>
		</footer>
	</body>
</html>
